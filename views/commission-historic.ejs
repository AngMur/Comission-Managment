// NOVU CUSTOM SELECTS
// ══════════════════════════════════

function populateSelect(wrap, data, autoSelectId = null) {
  const container = wrap.querySelector('.novu-select-options');
  container.innerHTML = '';

  // Opción "Todos" para limpiar el filtro
  const allOpt = document.createElement('div');
  allOpt.className   = 'novu-select-option';
  allOpt.textContent = '— Todos —';
  allOpt.dataset.value = '';
  allOpt.addEventListener('click', () => selectNovuOption(wrap, allOpt));
  container.appendChild(allOpt);

  if (!data || !data.length) {
    container.innerHTML += '<div class="novu-no-results">No hay datos disponibles</div>';
    return;
  }
  data.forEach(item => {
    const opt = document.createElement('div');
    opt.className        = 'novu-select-option';
    opt.textContent      = item.nombre;
    opt.dataset.value    = item.id;
    if (item.compania)   opt.dataset.compania   = item.compania;
    if (item.desarrollo) opt.dataset.desarrollo = item.desarrollo;
    opt.addEventListener('click', () => selectNovuOption(wrap, opt));
    container.appendChild(opt);
  });
  if (autoSelectId) {
    const target = container.querySelector(`[data-value="${autoSelectId}"]`);
    if (target) selectNovuOption(wrap, target, true);
  }
}

function selectNovuOption(wrap, optEl, isAuto = false) {
  const display   = wrap.querySelector('.novu-select-display');
  const container = wrap.querySelector('.novu-select-options');
  container.querySelectorAll('.novu-select-option').forEach(o => o.classList.remove('selected'));
  optEl.classList.add('selected');

  const isEmpty = !optEl.dataset.value;

  // Texto del display
  if (isEmpty) {
    const field = wrap.dataset.field;
    const placeholders = { compania:'Todas las compañías', desarrollo:'Todos los desarrollos', ubicacion:'Todas las ubicaciones' };
    display.textContent = placeholders[field] || '—';
    display.classList.add('placeholder');
  } else {
    display.textContent = optEl.textContent;
    display.classList.remove('placeholder');
  }

  display.dataset.value      = optEl.dataset.value    || '';
  display.dataset.compania   = optEl.dataset.compania  || '';
  display.dataset.desarrollo = optEl.dataset.desarrollo|| '';
  display.classList.remove('auto-selected');

  if (isAuto && !isEmpty) {
    display.classList.add('auto-selected');
    const badge = document.createElement('span');
    badge.className = 'novu-auto-badge';
    badge.innerHTML = '<i class="fas fa-magic"></i> Auto';
    display.appendChild(badge);
    setTimeout(() => { badge.remove(); display.classList.remove('auto-selected'); }, 3000);
  }

  const arrow = document.createElement('i');
  arrow.className = 'fas fa-chevron-down novu-select-arrow';
  display.appendChild(arrow);

  closeAllNovuSelects();

  // ── Lógica encadenada ──────────────────────────────────────────────────
  const field = wrap.dataset.field;
  const val   = optEl.dataset.value;

  if (field === 'compania') {
    filters.compania   = val || null;
    filters.desarrollo = null;
    filters.ubicacion  = null;
    clearNovuSelect('desarrollo');
    clearNovuSelect('ubicacion');
    const devsFiltrados = val ? _allData.desarrollos.filter(d => d.compania == val) : _allData.desarrollos;
    populateSelect(getWrap('desarrollo'), devsFiltrados);
    populateSelect(getWrap('ubicacion'),  val ? [] : _allData.ubicaciones);
  }

  if (field === 'desarrollo') {
    // Auto-seleccionar compañía
    if (!isAuto && val) {
      const dev = _allData.desarrollos.find(d => d.id == val);
      if (dev && dev.compania) {
        const cWrap = getWrap('compania');
        if (!cWrap.querySelector('.novu-select-display').dataset.value) {
          const cOpt = cWrap.querySelector(`[data-value="${dev.compania}"]`);
          if (cOpt) selectNovuOption(cWrap, cOpt, true);
        }
      }
    }
    filters.desarrollo = val || null;
    filters.ubicacion  = null;
    clearNovuSelect('ubicacion');
    const ubsFiltradas = val ? _allData.ubicaciones.filter(u => u.desarrollo == val) : _allData.ubicaciones;
    populateSelect(getWrap('ubicacion'), ubsFiltradas);
  }

  if (field === 'ubicacion') {
    // Auto-seleccionar desarrollo y compañía si vacíos
    if (!isAuto && val) {
      const devId = optEl.dataset.desarrollo;
      if (devId) {
        const dev = _allData.desarrollos.find(d => d.id == devId);
        if (dev) {
          const dWrap = getWrap('desarrollo');
          if (!dWrap.querySelector('.novu-select-display').dataset.value) {
            if (dev.compania) {
              const cWrap = getWrap('compania');
              const cOpt  = cWrap.querySelector(`[data-value="${dev.compania}"]`);
              if (cOpt) { selectNovuOption(cWrap, cOpt, true); populateSelect(dWrap, _allData.desarrollos.filter(d => d.compania == dev.compania)); }
            }
            const dOpt = dWrap.querySelector(`[data-value="${dev.id}"]`);
            if (dOpt) { selectNovuOption(dWrap, dOpt, true); }
          }
        }
      }
    }
    filters.ubicacion = val || null;
  }

  updateClearBtn();
  loadAndRender();
}

function clearNovuSelect(field) {
  const wrap = getWrap(field);
  if (!wrap) return;
  const display = wrap.querySelector('.novu-select-display');
  const placeholders = { compania:'Todas las compañías', desarrollo:'Todos los desarrollos', ubicacion:'Todas las ubicaciones' };
  display.textContent = placeholders[field] || '—';
  display.classList.add('placeholder');
  display.classList.remove('auto-selected');
  display.dataset.value      = '';
  display.dataset.compania   = '';
  display.dataset.desarrollo = '';
  const arrow = document.createElement('i');
  arrow.className = 'fas fa-chevron-down novu-select-arrow';
  display.appendChild(arrow);
  wrap.querySelector('.novu-select-options').querySelectorAll('.novu-select-option').forEach(o => o.classList.remove('selected'));
}

function getWrap(field) { return document.querySelector(`.novu-custom-select[data-field="${field}"]`); }

function closeAllNovuSelects() {
  document.querySelectorAll('.novu-select-dropdown.active').forEach(dd => {
    dd.classList.remove('active');
    dd.previousElementSibling.classList.remove('active');
    const inp = dd.querySelector('.novu-select-search input');
    if (inp) { inp.value = ''; dd.querySelectorAll('.novu-select-option').forEach(o => o.classList.remove('hidden')); }
    const nr = dd.querySelector('.novu-no-results');
    if (nr) nr.remove();
  });
}

function initNovuSelect(wrap) {
  const display  = wrap.querySelector('.novu-select-display');
  const dropdown = wrap.querySelector('.novu-select-dropdown');
  const search   = wrap.querySelector('.novu-select-search input');

  display.addEventListener('click', e => {
    e.stopPropagation();
    if (display.classList.contains('loading')) return;
    closeAllNovuSelects();
    dropdown.classList.toggle('active');
    display.classList.toggle('active');
    if (dropdown.classList.contains('active')) search.focus();
  });

  search.addEventListener('input', function() {
    const term = this.value.toLowerCase();
    let any = false;
    wrap.querySelectorAll('.novu-select-option').forEach(o => {
      if (!o.dataset.value) { o.classList.remove('hidden'); return; } // siempre muestra "Todos"
      const match = o.textContent.toLowerCase().includes(term);
      o.classList.toggle('hidden', !match);
      if (match) any = true;
    });
    let nr = dropdown.querySelector('.novu-no-results');
    if (!any && term) {
      if (!nr) { nr = document.createElement('div'); nr.className = 'novu-no-results'; nr.textContent = 'Sin resultados'; dropdown.appendChild(nr); }
    } else if (nr) nr.remove();
  });

  // No stopPropagation en dropdown — el listener global ya filtra con closest()
}

async function loadNovuSelector(wrap) {
  const api     = wrap.dataset.api;
  const display = wrap.querySelector('.novu-select-display');
  const arrow   = wrap.querySelector('.novu-select-arrow');
  const opts    = wrap.querySelector('.novu-select-options');

  display.classList.add('loading');
  display.textContent = 'Cargando...';
  if (arrow) arrow.className = 'fas fa-spinner novu-select-arrow';
  opts.innerHTML = '<div class="novu-loading-msg"><i class="fas fa-spinner"></i> Cargando...</div>';

  try {
    const data = await fetchAPI(api);
    display.classList.remove('loading');
    const field = wrap.dataset.field;
    const placeholders = { compania:'Todas las compañías', desarrollo:'Todos los desarrollos', ubicacion:'Todas las ubicaciones' };
    display.textContent = placeholders[field] || '—';
    display.classList.add('placeholder');
    const newArrow = document.createElement('i');
    newArrow.className = 'fas fa-chevron-down novu-select-arrow';
    display.appendChild(newArrow);
    populateSelect(wrap, data);
  } catch {
    display.classList.remove('loading');
    display.textContent = 'Error al cargar';
    if (arrow) arrow.className = 'fas fa-exclamation-circle novu-select-arrow';
    opts.innerHTML = '<div class="novu-error-msg"><i class="fas fa-exclamation-triangle"></i> Error al cargar.</div>';
  }
}

document.addEventListener('click', (e) => {
  // Solo cerrar si el click NO fue dentro de un selector
  if (!e.target.closest('.novu-custom-select')) closeAllNovuSelects();
});

// ══════════════════════════════════
// RENDER HELPERS
// ══════════════════════════════════
function phaseTotal(fase) {
  if (!fase) return 0;
  return (fase.participantes || []).reduce((a, p) => a + (p.earn || p.commission || 0), 0);
}

function buildParticipants(participantes) {
  return (participantes || []).map(p => `
    <div class="p-item">
      <div class="p-av ${p.avatar || 'av-green'}">${p.initials || (p.name||'?').slice(0,2).toUpperCase()}</div>
      <div class="p-data">
        <div class="p-name">${p.name || p.user}</div>
        <div class="p-role">${p.role || ''}</div>
      </div>
      <div class="p-nums">
        <div class="p-pct">${p.pct || ((p.percentage||0)*100).toFixed(1)}%</div>
        <div class="p-amt">${fmt(p.earn || p.commission || 0)}</div>
      </div>
    </div>`).join('');
}

function buildPhaseCol(fase, tipo) {
  const colorClass = tipo === 'contrato' ? 'contrato-col' : 'escritura-col';
  const label = tipo === 'contrato' ? 'Contrato' : 'Escritura';
  const icon  = tipo === 'contrato' ? 'fas fa-file-signature' : 'fas fa-stamp';
  if (!fase) return `
    <div class="phase-col ${colorClass}">
      <div class="phase-col-header">
        <div class="phase-col-icon"><i class="${icon}"></i></div>
        <div><div class="phase-col-title">${label}</div></div>
      </div>
      <div class="empty-phase"><i class="fas fa-clock"></i><p>Aún no registrada</p></div>
    </div>`;
  const total = phaseTotal(fase);
  return `
    <div class="phase-col ${colorClass}">
      <div class="phase-col-header">
        <div class="phase-col-icon"><i class="${icon}"></i></div>
        <div>
          <div class="phase-col-title">${label}</div>
          <div class="phase-col-date"><i class="fas fa-calendar-alt" style="margin-right:4px;opacity:0.6;"></i>${fase.fecha || fase.operation_date || ''}</div>
        </div>
      </div>
      <div class="phase-price-row">
        <div>
          <div class="phase-price-label">Precio de venta</div>
          <div class="phase-price-val">${fmt(fase.precio || fase.sale_price || 0)}</div>
        </div>
        <div style="text-align:right;">
          <div class="phase-price-label">Comisión total</div>
          <div class="phase-commission-total">${fmt(total)}</div>
        </div>
      </div>
      <div class="p-list">${buildParticipants(fase.participantes)}</div>
    </div>`;
}

function buildLocationBlock(loc, idx) {
  const cTotal = phaseTotal(loc.contrato);
  const eTotal = phaseTotal(loc.escritura);
  const grand  = cTotal + eTotal;
  const hasCon = !!loc.contrato;
  const hasEsc = !!loc.escritura;

  const cPill = hasCon
    ? `<div class="phase-pill contrato"><div class="phase-dot"></div>Contrato</div>`
    : `<div class="phase-pill missing"><div class="phase-dot"></div>Sin contrato</div>`;
  const ePill = hasEsc
    ? `<div class="phase-pill escritura"><div class="phase-dot"></div>Escritura</div>`
    : `<div class="phase-pill missing"><div class="phase-dot"></div>Sin escritura</div>`;

  const block = document.createElement('div');
  block.className = 'location-block';
  block.id = `loc-${loc.id}`;
  block.dataset.search = `${loc.id} ${loc.desarrollo} ${loc.empresa} ${loc.concepto} ${loc.contrato?.participantes?.map(p=>p.name).join(' ')||''} ${loc.escritura?.participantes?.map(p=>p.name).join(' ')||''}`.toLowerCase();
  block.style.animationDelay = `${idx * 0.06}s`;
  block.innerHTML = `
    <div class="loc-header" onclick="toggleLoc('${loc.id}')">
      <div class="loc-icon"><i class="fas fa-building"></i></div>
      <div class="loc-info">
        <div class="loc-id">${loc.id}</div>
        <div class="loc-name">${loc.desarrollo} — ${loc.concepto}</div>
        <div class="loc-empresa">${loc.empresa}</div>
      </div>
      <div class="loc-phases">${cPill}${ePill}</div>
      <div class="loc-total">
        <div class="loc-total-label">Total comisiones</div>
        <div class="loc-total-amt">${fmt(grand)}</div>
      </div>
      <div class="chevron">▾</div>
    </div>
    <div class="phases-body" id="pb-${loc.id}">
      <div class="phases-grid">
        ${buildPhaseCol(loc.contrato, 'contrato')}
        ${buildPhaseCol(loc.escritura, 'escritura')}
      </div>
      <div class="loc-totals-row">
        <div class="loc-total-cell">
          <div class="ltc-icon c"><i class="fas fa-file-signature"></i></div>
          <div><div class="ltc-label">Total Contrato</div><div class="ltc-val c">${hasCon ? fmt(cTotal) : '—'}</div></div>
        </div>
        <div class="loc-total-cell">
          <div class="ltc-icon e"><i class="fas fa-stamp"></i></div>
          <div><div class="ltc-label">Total Escritura</div><div class="ltc-val e">${hasEsc ? fmt(eTotal) : '—'}</div></div>
        </div>
      </div>
    </div>`;
  return block;
}

function toggleLoc(id) {
  const block  = document.getElementById(`loc-${id}`);
  const isOpen = block.classList.contains('open');
  document.querySelectorAll('.location-block.open').forEach(b => b.classList.remove('open'));
  if (!isOpen) block.classList.add('open');
}

// ── Summary ─────────────────────────────────────────────────────────────────
function renderSummary(data) {
  const totalC = data.reduce((a, l) => a + phaseTotal(l.contrato), 0);
  const totalE = data.reduce((a, l) => a + phaseTotal(l.escritura), 0);
  document.getElementById('summaryRow').innerHTML = `
    <div class="sum-pill"><span>Ubicaciones</span><strong>${data.length}</strong></div>
    <div class="sum-pill c-contrato"><span>Comisiones Contrato</span><strong>${fmt(totalC)}</strong></div>
    <div class="sum-pill c-escritura"><span>Comisiones Escritura</span><strong>${fmt(totalE)}</strong></div>
    <div class="sum-pill c-total"><span>Gran Total</span><strong>${fmt(totalC + totalE)}</strong></div>`;
}

// ── Botón limpiar ────────────────────────────────────────────────────────────
function updateClearBtn() {
  const active = filters.compania || filters.desarrollo || filters.ubicacion;
  document.getElementById('btnClear').classList.toggle('hidden', !active);
}

document.getElementById('btnClear').addEventListener('click', () => {
  filters.compania = filters.desarrollo = filters.ubicacion = null;
  clearNovuSelect('compania');
  clearNovuSelect('desarrollo');
  clearNovuSelect('ubicacion');
  // Repoblar desarrollos y ubicaciones completos
  populateSelect(getWrap('desarrollo'), _allData.desarrollos);
  populateSelect(getWrap('ubicacion'),  _allData.ubicaciones);
  updateClearBtn();
  loadAndRender();
});

// ── Carga + render principal ─────────────────────────────────────────────────
async function loadAndRender() {
  const list = document.getElementById('locationList');
  list.innerHTML = `<div class="list-loading"><i class="fas fa-spinner"></i> Cargando comisiones…</div>`;

  let data;
  try {
    data = await fetchComisiones();
  } catch (e) {
    list.innerHTML = `<div class="no-results"><i class="fas fa-exclamation-triangle"></i>Error al cargar comisiones</div>`;
    renderSummary([]);
    return;
  }

  // Filtro de búsqueda de texto (client-side sobre lo que llegó)
  const term = filters.search;
  const filtered = term
    ? data.filter(l => `${l.id} ${l.desarrollo} ${l.empresa} ${l.concepto}`.toLowerCase().includes(term))
    : data;

  renderSummary(filtered);
  list.innerHTML = '';

  if (!filtered.length) {
    list.innerHTML = `<div class="no-results"><i class="fas fa-search"></i>Sin resultados</div>`;
    return;
  }
  filtered.forEach((loc, i) => list.appendChild(buildLocationBlock(loc, i)));
}

// ── Búsqueda de texto ────────────────────────────────────────────────────────
document.getElementById('searchInput').addEventListener('input', function() {
  filters.search = this.value.toLowerCase().trim();
  loadAndRender();
});

// ── Stars ────────────────────────────────────────────────────────────────────
const starsEl = document.getElementById('stars');
for (let i = 0; i < 90; i++) {
  const s = document.createElement('div'); s.className = 'star';
  const sz = Math.random()*2.2+0.4;
  const colors = ['#ffffff','#7bc42a','#c8e88a'];
  s.style.cssText = `width:${sz}px;height:${sz}px;top:${Math.random()*100}%;left:${Math.random()*100}%;background:${colors[Math.floor(Math.random()*colors.length)]};--dur:${1.5+Math.random()*3}s;animation-delay:${Math.random()*3}s;`;
  starsEl.appendChild(s);
}

// ── Bootstrap ────────────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', async () => {
  const wraps = document.querySelectorAll('.novu-custom-select[data-api]');
  wraps.forEach(initNovuSelect);
  // Cargar selectores en secuencia (compañía → desarrollo → ubicación)
  for (const w of wraps) await loadNovuSelector(w);
  // Carga inicial de comisiones sin filtros
  await loadAndRender();
});
</script>
</body>
</html>