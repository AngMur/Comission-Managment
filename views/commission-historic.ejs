<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>NOVU — Historial</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;900&family=Space+Mono:wght@700&display=swap" rel="stylesheet"/>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
  --bg:#0f1e1e;--bg2:#162828;--bg3:#1c3030;--bg4:#223838;
  --green:#60a61e;--green-glow:rgba(96,166,30,0.3);--green-bright:#7bc42a;
  --white:#ffffff;--muted:#8fada0;
  --amber:#f0a500;--blue:#38c5f5;--red:#e74c3c;--teal:#10b981;
  --contrato:#38c5f5;--escritura:#7bc42a;
}
body{background:var(--bg);color:var(--white);font-family:'Nunito',sans-serif;min-height:100vh;overflow-x:hidden;}

.stars{position:fixed;inset:0;pointer-events:none;z-index:0;}
.star{position:absolute;border-radius:50%;animation:twinkle var(--dur) ease-in-out infinite alternate;}
@keyframes twinkle{from{opacity:0.15;}to{opacity:0.85;}}
.beam{position:fixed;top:0;right:10%;width:280px;height:100vh;background:linear-gradient(180deg,rgba(96,166,30,0.06) 0%,transparent 65%);transform:skewX(-8deg);pointer-events:none;z-index:0;}

/* HEADER */
.header{position:relative;z-index:2;display:flex;align-items:center;justify-content:space-between;padding:2rem 5rem 1.4rem;border-bottom:1px solid rgba(96,166,30,0.15);flex-wrap:wrap;gap:1rem;}
.brand-name{font-family:'Space Mono',monospace;font-size:clamp(2.5rem,6vw,4.5rem);font-weight:700;letter-spacing:-2px;color:var(--white);text-shadow:0 0 60px var(--green-glow);}
.brand-name .dot{color:var(--green);}
.page-title{font-size:1rem;font-weight:900;color:var(--muted);letter-spacing:0.06em;text-transform:uppercase;margin-top:4px;}

/* CONTENT */
.content{position:relative;z-index:1;max-width:1000px;width:92%;margin:0 auto;padding:2.5rem 0 6rem;}

/* CONTROLS */
.controls-bar{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:1.8rem;animation:fadeUp 0.4s ease both;}
.search-wrap{position:relative;flex:1;min-width:220px;}
.search-wrap i{position:absolute;left:14px;top:50%;transform:translateY(-50%);color:var(--green);font-size:0.82rem;pointer-events:none;}
.search-input{width:100%;background:var(--bg2);border:1px solid rgba(96,166,30,0.18);border-radius:100px;padding:0.6rem 1rem 0.6rem 2.4rem;color:var(--white);font-family:'Nunito',sans-serif;font-size:0.85rem;font-weight:600;outline:none;transition:border-color 0.2s;}
.search-input::placeholder{color:rgba(143,173,160,0.35);font-weight:400;}
.search-input:focus{border-color:var(--green);}

/* SUMMARY PILLS */
.summary-row{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:1.8rem;animation:fadeUp 0.4s 0.1s ease both;}
.sum-pill{background:var(--bg2);border:1px solid rgba(96,166,30,0.15);border-radius:12px;padding:0.7rem 1.2rem;flex:1;min-width:140px;}
.sum-pill span{display:block;font-size:0.62rem;font-weight:800;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);margin-bottom:3px;}
.sum-pill strong{font-family:'Space Mono',monospace;font-size:1rem;color:var(--white);}
.sum-pill.c-contrato strong{color:var(--contrato);}
.sum-pill.c-escritura strong{color:var(--escritura);}
.sum-pill.c-total strong{color:var(--green-bright);}

@keyframes fadeUp{from{opacity:0;transform:translateY(14px);}to{opacity:1;transform:translateY(0);}}

/* LOCATION BLOCK */
.location-block{background:var(--bg2);border:1px solid rgba(96,166,30,0.14);border-radius:18px;overflow:hidden;margin-bottom:14px;animation:fadeUp 0.5s ease both;}
.loc-header{display:flex;align-items:center;gap:14px;padding:1.1rem 1.4rem;cursor:pointer;user-select:none;transition:background 0.2s;border-bottom:1px solid rgba(96,166,30,0.08);}
.loc-header:hover{background:rgba(96,166,30,0.04);}
.loc-icon{width:40px;height:40px;border-radius:12px;background:linear-gradient(135deg,rgba(96,166,30,0.2),rgba(96,166,30,0.08));border:1px solid rgba(96,166,30,0.25);display:flex;align-items:center;justify-content:center;font-size:0.85rem;color:var(--green-bright);flex-shrink:0;}
.loc-info{flex:1;min-width:0;}
.loc-id{font-family:'Space Mono',monospace;font-size:0.72rem;color:var(--green-bright);font-weight:700;letter-spacing:0.04em;margin-bottom:2px;}
.loc-name{font-weight:900;font-size:0.98rem;color:var(--white);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.loc-empresa{font-size:0.7rem;color:var(--muted);font-weight:600;margin-top:2px;}
.loc-phases{display:flex;gap:8px;flex-shrink:0;}
.phase-pill{display:flex;align-items:center;gap:5px;padding:0.28rem 0.7rem;border-radius:100px;font-size:0.65rem;font-weight:900;letter-spacing:0.05em;text-transform:uppercase;}
.phase-pill.contrato{background:rgba(56,197,245,0.1);border:1px solid rgba(56,197,245,0.3);color:var(--contrato);}
.phase-pill.escritura{background:rgba(123,196,42,0.1);border:1px solid rgba(123,196,42,0.3);color:var(--escritura);}
.phase-pill.missing{background:rgba(143,173,160,0.06);border:1px solid rgba(143,173,160,0.15);color:rgba(143,173,160,0.4);}
.phase-dot{width:6px;height:6px;border-radius:50%;}
.phase-pill.contrato .phase-dot{background:var(--contrato);}
.phase-pill.escritura .phase-dot{background:var(--escritura);}
.phase-pill.missing .phase-dot{background:rgba(143,173,160,0.3);}
.loc-total{text-align:right;flex-shrink:0;}
.loc-total-label{font-size:0.62rem;color:var(--muted);font-weight:700;text-transform:uppercase;letter-spacing:0.08em;}
.loc-total-amt{font-family:'Space Mono',monospace;font-size:0.92rem;color:var(--white);font-weight:700;margin-top:1px;}
.chevron{width:22px;height:22px;border-radius:50%;border:1.5px solid rgba(96,166,30,0.3);display:flex;align-items:center;justify-content:center;color:var(--green);font-size:11px;transition:transform 0.3s,background 0.2s;flex-shrink:0;margin-left:6px;}
.location-block.open .chevron{transform:rotate(180deg);background:rgba(96,166,30,0.12);border-color:rgba(96,166,30,0.6);}

/* PHASES GRID */
.phases-body{max-height:0;overflow:hidden;transition:max-height 0.45s cubic-bezier(0.4,0,0.2,1);}
.location-block.open .phases-body{max-height:1200px;}
.phases-grid{display:grid;grid-template-columns:1fr 1fr;gap:0;}

/* PHASE COLUMN */
.phase-col{padding:1.2rem 1.4rem;position:relative;}
.phase-col.contrato-col{border-right:1px solid rgba(56,197,245,0.1);}
.phase-col-header{display:flex;align-items:center;gap:8px;margin-bottom:1rem;padding-bottom:0.7rem;border-bottom:1px solid;}
.contrato-col .phase-col-header{border-color:rgba(56,197,245,0.15);}
.escritura-col .phase-col-header{border-color:rgba(123,196,42,0.15);}
.phase-col-icon{width:28px;height:28px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:0.72rem;flex-shrink:0;}
.contrato-col .phase-col-icon{background:rgba(56,197,245,0.12);color:var(--contrato);}
.escritura-col .phase-col-icon{background:rgba(123,196,42,0.12);color:var(--escritura);}
.phase-col-title{font-weight:900;font-size:0.88rem;}
.contrato-col .phase-col-title{color:var(--contrato);}
.escritura-col .phase-col-title{color:var(--escritura);}
.phase-col-date{font-size:0.68rem;color:var(--muted);margin-top:1px;font-weight:600;}
.phase-price-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;padding:0.6rem 0.8rem;border-radius:10px;background:var(--bg3);}
.phase-price-label{font-size:0.65rem;color:var(--muted);font-weight:700;text-transform:uppercase;letter-spacing:0.08em;}
.phase-price-val{font-family:'Space Mono',monospace;font-size:0.9rem;color:var(--white);}
.phase-commission-total{font-size:0.7rem;font-weight:700;margin-top:2px;}
.contrato-col .phase-commission-total{color:var(--contrato);}
.escritura-col .phase-commission-total{color:var(--escritura);}

/* PARTICIPANTS */
.p-list{display:flex;flex-direction:column;gap:8px;}
.p-item{display:flex;align-items:center;gap:10px;padding:0.65rem 0.8rem;background:var(--bg3);border-radius:10px;border:1px solid rgba(96,166,30,0.08);transition:border-color 0.2s;}
.p-item:hover{border-color:rgba(96,166,30,0.2);}
.p-av{width:32px;height:32px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-weight:900;font-size:0.75rem;font-family:'Space Mono',monospace;flex-shrink:0;}
.av-teal{background:linear-gradient(135deg,#38c5f5,#1a8bb5);color:#0a1a24;}
.av-green{background:linear-gradient(135deg,#7bc42a,#4a8518);color:#0f1e1e;}
.av-pink{background:linear-gradient(135deg,#f08080,#c04040);color:#fff;}
.av-amber{background:linear-gradient(135deg,#f0c040,#c88a10);color:#0f1e1e;}
.av-purple{background:linear-gradient(135deg,#b080f0,#7040c0);color:#fff;}
.p-data{flex:1;min-width:0;}
.p-name{font-weight:900;font-size:0.8rem;color:var(--white);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.p-role{font-size:0.6rem;color:var(--muted);font-weight:700;text-transform:uppercase;letter-spacing:0.06em;}
.p-nums{text-align:right;flex-shrink:0;}
.p-pct{font-size:0.65rem;color:var(--muted);}
.p-amt{font-family:'Space Mono',monospace;font-size:0.8rem;font-weight:700;}
.contrato-col .p-amt{color:var(--contrato);}
.escritura-col .p-amt{color:var(--escritura);}

/* EMPTY PHASE */
.empty-phase{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:2.5rem 1rem;gap:10px;opacity:0.45;}
.empty-phase i{font-size:1.8rem;color:var(--muted);}
.empty-phase p{font-size:0.78rem;font-weight:700;color:var(--muted);text-align:center;}

/* TOTALS ROW */
.loc-totals-row{display:flex;gap:0;border-top:1px solid rgba(96,166,30,0.1);}
.loc-total-cell{flex:1;padding:0.8rem 1.4rem;display:flex;align-items:center;gap:10px;}
.loc-total-cell:first-child{border-right:1px solid rgba(96,166,30,0.08);}
.ltc-label{font-size:0.62rem;font-weight:800;text-transform:uppercase;letter-spacing:0.1em;color:var(--muted);}
.ltc-val{font-family:'Space Mono',monospace;font-size:0.88rem;font-weight:700;margin-top:1px;}
.ltc-val.c{color:var(--contrato);}
.ltc-val.e{color:var(--escritura);}
.ltc-icon{width:28px;height:28px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:0.7rem;flex-shrink:0;}
.ltc-icon.c{background:rgba(56,197,245,0.1);color:var(--contrato);}
.ltc-icon.e{background:rgba(123,196,42,0.1);color:var(--escritura);}

/* ════════════════════════════════
   FILTROS — NOVU SELECTORS
   ════════════════════════════════ */
.filters-section{background:var(--bg2);border:1px solid rgba(96,166,30,0.14);border-radius:16px;padding:1.2rem 1.4rem;margin-bottom:1.4rem;animation:fadeUp 0.4s 0.15s ease both;}
.filters-title{font-size:0.68rem;font-weight:900;letter-spacing:0.12em;text-transform:uppercase;color:var(--muted);margin-bottom:1rem;display:flex;align-items:center;gap:8px;}
.filters-title i{color:var(--green);}
.filters-groups{display:flex;gap:1.4rem;flex-wrap:wrap;}
.filter-group{flex:1;min-width:200px;}
.filter-group-label{font-size:0.62rem;font-weight:900;letter-spacing:0.12em;text-transform:uppercase;color:var(--muted);margin-bottom:0.5rem;display:flex;align-items:center;gap:6px;}
.filter-group-label i{color:var(--green);font-size:0.7rem;}

/* Botón limpiar */
.filters-footer{display:flex;align-items:center;justify-content:space-between;margin-top:1rem;flex-wrap:wrap;gap:8px;}
.filters-clear{display:inline-flex;align-items:center;gap:5px;font-size:0.68rem;font-weight:800;color:var(--muted);cursor:pointer;letter-spacing:0.06em;text-transform:uppercase;transition:color 0.2s;background:none;border:none;padding:0;}
.filters-clear:hover{color:var(--red);}
.filters-clear.hidden{display:none;}

/* Estado de carga de la lista */
.list-loading{display:flex;align-items:center;justify-content:center;gap:12px;padding:3rem;color:var(--green);font-weight:700;font-size:0.9rem;}
.list-loading i{font-size:1.4rem;animation:novuSpin 1s linear infinite;}

/* NO RESULTS */
.no-results{text-align:center;padding:4rem;color:var(--muted);opacity:0.6;}
.no-results i{font-size:2.2rem;margin-bottom:0.8rem;display:block;}

/* ════════════════════════════════
   NOVU CUSTOM SELECT (inline)
   ════════════════════════════════ */
.novu-custom-select{position:relative;}
.novu-select-display{
  background:var(--bg3);border:1px solid rgba(96,166,30,0.2);
  border-radius:10px;padding:0.6rem 2.4rem 0.6rem 0.9rem;
  color:var(--white);font-family:'Nunito',sans-serif;font-size:0.82rem;font-weight:700;
  transition:all 0.3s;cursor:pointer;user-select:none;
  min-height:38px;display:flex;align-items:center;
}
.novu-select-display.placeholder{color:rgba(143,173,160,0.5);}
.novu-select-display.loading{color:var(--muted);cursor:wait;}
.novu-select-display.auto-selected{border-color:rgba(96,166,30,0.5);background:rgba(96,166,30,0.06);}
.novu-select-display:hover:not(.loading){border-color:rgba(96,166,30,0.45);}
.novu-select-display.active{background:rgba(28,48,48,0.95);border-color:var(--green);box-shadow:0 0 0 3px rgba(96,166,30,0.1);}

.novu-select-arrow{position:absolute;right:10px;top:50%;transform:translateY(-50%);color:var(--green);font-size:0.72rem;pointer-events:none;transition:transform 0.3s;}
.novu-select-display.active .novu-select-arrow{transform:translateY(-50%) rotate(180deg);}
.novu-select-display.loading .novu-select-arrow{animation:novuSpin 1s linear infinite;}

@keyframes novuSpin{from{transform:translateY(-50%) rotate(0deg);}to{transform:translateY(-50%) rotate(360deg);}}

.novu-select-dropdown{
  position:absolute;top:calc(100% + 5px);left:0;right:0;
  background:rgba(18,32,32,0.99);backdrop-filter:blur(12px);
  border:1px solid rgba(96,166,30,0.3);border-radius:12px;
  max-height:0;overflow:hidden;opacity:0;
  transition:all 0.3s ease;z-index:1000;
  box-shadow:0 12px 32px rgba(0,0,0,0.55);
}
.novu-select-dropdown.active{max-height:320px;opacity:1;overflow-y:auto;}
.novu-select-search{padding:10px;border-bottom:1px solid rgba(255,255,255,0.05);position:sticky;top:0;background:rgba(18,32,32,0.99);z-index:10;}
.novu-select-search input{
  width:100%;background:rgba(30,48,48,0.8);border:1px solid rgba(255,255,255,0.08);
  border-radius:8px;padding:8px 30px 8px 10px;color:var(--white);
  font-size:0.8rem;font-family:'Nunito',sans-serif;outline:none;transition:all 0.2s;
}
.novu-select-search input:focus{border-color:var(--green);box-shadow:0 0 0 2px rgba(96,166,30,0.1);}
.novu-select-search .nsearch-icon{position:absolute;right:20px;top:50%;transform:translateY(-50%);color:var(--green);font-size:0.75rem;}
.novu-select-options{padding:4px;}
.novu-select-option{padding:10px 12px;cursor:pointer;border-radius:8px;transition:all 0.15s;color:var(--white);font-size:0.85rem;font-weight:600;}
.novu-select-option:hover{background:rgba(96,166,30,0.15);}
.novu-select-option.selected{background:rgba(96,166,30,0.22);color:var(--green-bright);}
.novu-select-option.hidden{display:none;}
.novu-no-results{padding:18px;text-align:center;color:var(--muted);font-size:0.82rem;}
.novu-loading-msg{padding:18px;text-align:center;color:var(--green);font-size:0.82rem;}
.novu-loading-msg i{animation:novuSpin 1s linear infinite;display:inline-block;margin-right:6px;}
.novu-error-msg{padding:18px;text-align:center;color:#ff6b6b;font-size:0.82rem;}
.novu-auto-badge{display:inline-flex;align-items:center;gap:4px;background:rgba(96,166,30,0.18);border:1px solid rgba(96,166,30,0.35);color:var(--green);padding:1px 7px;border-radius:10px;font-size:0.65rem;font-weight:700;margin-left:6px;}
.novu-select-dropdown::-webkit-scrollbar{width:6px;}
.novu-select-dropdown::-webkit-scrollbar-track{background:rgba(30,48,48,0.5);border-radius:6px;}
.novu-select-dropdown::-webkit-scrollbar-thumb{background:rgba(96,166,30,0.45);border-radius:6px;}

@media(max-width:680px){
  .header{padding:1.5rem 1.2rem 1.2rem;}
  .phases-grid{grid-template-columns:1fr;}
  .phase-col.contrato-col{border-right:none;border-bottom:1px solid rgba(56,197,245,0.1);}
  .loc-phases{display:none;}
  .loc-totals-row{flex-direction:column;}
  .loc-total-cell:first-child{border-right:none;border-bottom:1px solid rgba(96,166,30,0.08);}
  .filters-groups{flex-direction:column;}
}
</style>
</head>
<body>
<div class="stars" id="stars"></div>
<div class="beam"></div>

<header class="header">
  <div>
    <div class="brand-name"><span class="dot">NO</span>VU</div>
    <div class="page-title"><i class="fas fa-history" style="color:var(--green);margin-right:6px;"></i>Historial de Comisiones</div>
  </div>
</header>

<main class="content">

  <!-- SUMMARY -->
  <div class="summary-row" id="summaryRow"></div>

  <!-- SEARCH -->
  <div class="controls-bar">
    <div class="search-wrap">
      <i class="fas fa-search"></i>
      <input class="search-input" id="searchInput" type="text" placeholder="Buscar por clave, desarrollo, empresa, asesor…">
    </div>
  </div>

  <!-- FILTERS con selectores NOVU -->
  <div class="filters-section">
    <div class="filters-title"><i class="fas fa-filter"></i> Filtros</div>
    <div class="filters-groups">

      <!-- Compañía -->
      <div class="filter-group">
        <div class="filter-group-label"><i class="fas fa-city"></i> Compañía</div>
        <div class="novu-custom-select" data-field="compania" data-api="/v10/companias">
          <div class="novu-select-display placeholder">
            Todas las compañías
            <i class="fas fa-chevron-down novu-select-arrow"></i>
          </div>
          <div class="novu-select-dropdown">
            <div class="novu-select-search">
              <input type="text" placeholder="Buscar compañía...">
              <i class="fas fa-search nsearch-icon"></i>
            </div>
            <div class="novu-select-options"></div>
          </div>
        </div>
      </div>

      <!-- Desarrollo -->
      <div class="filter-group">
        <div class="filter-group-label"><i class="fas fa-building"></i> Desarrollo</div>
        <div class="novu-custom-select" data-field="desarrollo" data-api="/v10/desarrollos">
          <div class="novu-select-display placeholder">
            Todos los desarrollos
            <i class="fas fa-chevron-down novu-select-arrow"></i>
          </div>
          <div class="novu-select-dropdown">
            <div class="novu-select-search">
              <input type="text" placeholder="Buscar desarrollo...">
              <i class="fas fa-search nsearch-icon"></i>
            </div>
            <div class="novu-select-options"></div>
          </div>
        </div>
      </div>

      <!-- Ubicación -->
      <div class="filter-group">
        <div class="filter-group-label"><i class="fas fa-map-marker-alt"></i> Ubicación</div>
        <div class="novu-custom-select" data-field="ubicacion" data-api="/v10/ubicaciones">
          <div class="novu-select-display placeholder">
            Todas las ubicaciones
            <i class="fas fa-chevron-down novu-select-arrow"></i>
          </div>
          <div class="novu-select-dropdown">
            <div class="novu-select-search">
              <input type="text" placeholder="Buscar ubicación...">
              <i class="fas fa-search nsearch-icon"></i>
            </div>
            <div class="novu-select-options"></div>
          </div>
        </div>
      </div>

    </div>
    <div class="filters-footer">
      <button class="filters-clear hidden" id="btnClear"><i class="fas fa-times"></i> Limpiar filtros</button>
    </div>
  </div>

  <!-- LIST -->
  <div id="locationList"></div>

</main>

<!-- ══════════════════════════════════════════
     SCRIPTS
══════════════════════════════════════════ -->
<script>
// ── Helpers de formato ──────────────────────────────────────────────────────
const fmt = n => '$' + Number(n).toLocaleString('es-MX');

// ── Estado de filtros ───────────────────────────────────────────────────────
const filters = { compania: null, desarrollo: null, ubicacion: null, search: '' };

// ── Caché API y datos maestros ──────────────────────────────────────────────
const _apiCache = {};
const _allData  = { desarrollos: [], ubicaciones: [] };

// ── Fetch con cache ─────────────────────────────────────────────────────────
// TODO: cuando los endpoints esten listos, elimina el bloque MOCK_APIS y
// descomenta el fetch real de abajo.
const MOCK_APIS = {
  '/v10/companias': [
    { id:'1', nombre:'Grupo Punta Diamante' },
    { id:'2', nombre:'Desarrollos del Pacifico' },
