    </div>`;
}

// ── Acciones Gerente ──────────────────────────────────────────────────────────
function editarComision(comisionId) {
  // TODO: redirigir a /editar-comision/:id
  
  window.location.href = `/registrar-comision?edit=${comisionId}`;

  // alert(`Editar comisión: ${comisionId}`);
}


function eliminarComision(comisionId, locationText) {
  console.log(comisionId);
  // Crear modal de confirmación
  if (document.getElementById('deleteModal')) return;

  const overlay = document.createElement('div');
  overlay.className = 'modal-overlay';
  overlay.id = 'deleteModal';
  overlay.innerHTML = `
    <div class="modal" role="dialog" aria-modal="true">
      <div class="modal-icon" style="background:var(--red-bg)">
        <i class="ti ti-trash" style="color:var(--red-tx)"></i>
      </div>
      <h3>Eliminar comisión</h3>
      <p>¿Seguro que quieres eliminar <strong>${locationText}</strong>?
         Esta acción no se puede deshacer y eliminará también a todos sus participantes.</p>
      <div class="modal-btns">
        <button class="mbtn" onclick="closeDeleteModal()">Cancelar</button>
        <button class="mbtn mbtn-danger" id="confirmDeleteBtn" onclick="doEliminar('${comisionId}')">
          Eliminar
        </button>
      </div>
    </div>`;

  overlay.addEventListener('click', e => { if (e.target === overlay) closeDeleteModal(); });
  document.body.appendChild(overlay);
}

function closeDeleteModal() {
  const m = document.getElementById('deleteModal');
  if (m) m.remove();
}

async function doEliminar(comisionId) {
  const btn = document.getElementById('confirmDeleteBtn');
  btn.disabled = true;
  btn.textContent = 'Eliminando…';

  try {
    const r = await fetch(`/api/comisiones/eliminar/${comisionId}`, {
      method:      'DELETE',
      credentials: 'include',
    });
    const j = await r.json();

    closeDeleteModal();

    if (!j.success) {
      toast(j.message);
      return;
    }

    // Quitar la card del DOM sin recargar toda la lista
    rows = rows.filter(r => r.comision_id?.toString() !== comisionId &&
                            r._id?.toString()       !== comisionId);
    renderRows();
    toast('Comisión eliminada correctamente');

  } catch(e) {
    closeDeleteModal();
    toast('Error al eliminar la comisión');
  }
}

// ── Acciones comisiones ───────────────────────────────────────────────────────
async function verificar(comisionId) {
  try {
    const r = await fetch(`/api/comisiones/${comisionId}/verificar`, { method:'PATCH', credentials:'include' });
    const j = await r.json();
    toast(j.message);
    if (j.success) await reloadComision(comisionId);
  } catch(e) { toast('Error al verificar'); }
}

async function aprobar(comisionId, accion, correction_comments = null) {
  const body = { accion };
  if (correction_comments) body.correction_comments = correction_comments;
  try {
    const r = await fetch(`/api/comisiones/${comisionId}/aprobar`, {
      method:'PATCH', credentials:'include',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify(body),
    });
    const j = await r.json();
    toast(j.message);
    if (j.success) await reloadComision(comisionId);
  } catch(e) { toast('Error al procesar'); }
}

async function pagar(comisionId) {
  try {
    const r = await fetch(`/api/comisiones/${comisionId}/pagar`, { method:'PATCH', credentials:'include' });
    const j = await r.json();
    toast(j.message);
    if (j.success) await reloadComision(comisionId);
  } catch(e) { toast('Error al marcar como pagada'); }
}

function pedirCorreccion(comisionId) {
  const comentario = prompt('Indica el motivo de la corrección:');
  if (!comentario) return;
  aprobar(comisionId, 'correccion', comentario);
}

async function reloadComision() {
  const isLimitado = ['Asesor', 'Gerente'].includes(USER.roleName);
  await loadComisiones(isLimitado);
}

function showError(msg) {
  $('list').innerHTML = `<div class="state-msg"><i class="ti ti-alert-circle"></i>${msg}</div>`;
}

init();
</script>
</body>
</html>