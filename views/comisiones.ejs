<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Comisiones</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/styles/layout.css">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:       #f5f4f0;
      --surface:  #ffffff;
      --border:   #e2e0d8;
      --border-md:#c8c5bc;
      --text-1:   #1a1917;
      --text-2:   #6b6860;
      --text-3:   #9c9a94;
      --accent:   #1a1917;
      --green-bg: #eaf3de;
      --green-tx: #3b6d11;
      --green-br: #c0dd97;
      --amber-bg: #faeeda;
      --amber-tx: #854f0b;
      --amber-br: #fac775;
      --red-bg:   #fcebeb;
      --red-tx:   #a32d2d;
      --red-br:   #f7c1c1;
      --blue-bg:  #e6f1fb;
      --blue-tx:  #185fa5;
      --blue-br:  #b5d4f4;
      --gray-bg:  #f1efe8;
      --gray-tx:  #5f5e5a;
      --gray-br:  #d3d1c7;
      --radius:   10px;
      --radius-sm:6px;
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--text-1);
      min-height: 100vh;
    }

    /* ── Botón nueva comisión ── */
    .btn-new {
      display: flex; align-items: center; gap: 5px;
      font-size: 12px; font-weight: 500;
      padding: 5px 12px;
      border-radius: var(--radius-sm);
      border: 1px solid var(--text-1);
      background: var(--text-1);
      color: #fff;
      cursor: pointer;
      font-family: 'DM Sans', sans-serif;
      transition: opacity .15s;
      white-space: nowrap;
      text-decoration: none;
    }
    .btn-new:hover { opacity: .8; }
    .btn-new i { font-size: 14px; }

    /* ── Modal overlay ── */
    .modal-overlay {
      position: fixed; inset: 0;
      background: rgba(0,0,0,.35);
      display: flex; align-items: center; justify-content: center;
      z-index: 100;
      backdrop-filter: blur(2px);
      animation: fadeIn .15s ease;
    }
    @keyframes fadeIn { from { opacity:0 } to { opacity:1 } }

    .modal {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 24px;
      width: 300px;
      box-shadow: 0 8px 32px rgba(0,0,0,.1);
      animation: slideUp .18s ease;
    }
    @keyframes slideUp {
      from { opacity:0; transform:translateY(10px) }
      to   { opacity:1; transform:translateY(0) }
    }
    .modal-icon {
      width: 40px; height: 40px;
      border-radius: 50%;
      background: var(--red-bg);
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 14px;
    }
    .modal-icon i { font-size: 20px; color: var(--red-tx); }
    .modal h3 { font-size: 15px; font-weight: 500; margin-bottom: 6px; }
    .modal p  { font-size: 13px; color: var(--text-2); line-height: 1.6; margin-bottom: 20px; }
    .modal-btns { display: flex; gap: 8px; justify-content: flex-end; }
    .mbtn {
      padding: 7px 16px;
      border-radius: var(--radius-sm);
      font-size: 13px; font-weight: 500;
      border: 1px solid var(--border-md);
      background: transparent;
      color: var(--text-1);
      cursor: pointer;
      font-family: 'DM Sans', sans-serif;
      transition: background .12s;
    }
    .mbtn:hover { background: var(--bg); }
    .mbtn-danger {
      background: var(--text-1);
      color: #fff;
      border-color: var(--text-1);
    }
    .mbtn-danger:hover { background: #333; }
    .mbtn-danger:disabled { opacity: .5; cursor: not-allowed; }
    .mbtn-danger .spinner-sm {
      width: 13px; height: 13px;
      border: 2px solid rgba(255,255,255,.3);
      border-top-color: #fff;
      border-radius: 50%;
      animation: spin .6s linear infinite;
      display: inline-block;
      vertical-align: middle;
      margin-right: 4px;
    }

    /* ── Layout ── */
    .page { max-width: 860px; margin: 0 auto; padding: 2rem 1.5rem; }
    .page-header {
      display: flex; align-items: baseline;
      justify-content: space-between;
      margin-bottom: 1.75rem;
      gap: 12px; flex-wrap: wrap;
    }
    .page-title { font-size: 20px; font-weight: 500; }
    .page-count { font-size: 13px; color: var(--text-2); }

    /* ── Estado ── */
    .state-msg {
      text-align: center;
      padding: 4rem 1rem;
      color: var(--text-2);
      font-size: 14px;
    }
    .state-msg i { font-size: 36px; display: block; margin-bottom: 10px; color: var(--text-3); }

    /* ── Card ── */
    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      margin-bottom: 1rem;
      overflow: hidden;
      animation: fadeUp .25s ease both;
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(8px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .card-head {
      padding: 1.1rem 1.25rem .9rem;
      display: flex; align-items: flex-start;
      justify-content: space-between;
      gap: 12px;
      border-bottom: 1px solid var(--border);
    }
    .card-loc { font-family: 'DM Mono', monospace; font-size: 13px; font-weight: 500; }
    .card-dev { font-size: 12px; color: var(--text-2); margin-top: 2px; }

    /* head right: badge + gerente actions */
    .card-head-right { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
    .btn-icon {
      display: flex; align-items: center; justify-content: center;
      width: 28px; height: 28px;
      border-radius: var(--radius-sm);
      border: 1px solid var(--border-md);
      background: transparent;
      cursor: pointer;
      color: var(--text-2);
      transition: all .15s;
      font-size: 15px;
    }
    .btn-icon:hover { background: var(--bg); color: var(--text-1); border-color: var(--border-md); }
    .btn-icon.edit:hover  { background: var(--blue-bg);  color: var(--blue-tx);  border-color: var(--blue-br); }
    .btn-icon.delete:hover{ background: var(--red-bg);   color: var(--red-tx);   border-color: var(--red-br); }

    /* ── Badge ── */
    .badge {
      font-size: 11px; font-weight: 500;
      padding: 3px 9px;
      border-radius: 20px;
      border: 1px solid;
      white-space: nowrap;
    }
    .b-pv { background: var(--amber-bg); color: var(--amber-tx); border-color: var(--amber-br); }
    .b-v  { background: var(--blue-bg);  color: var(--blue-tx);  border-color: var(--blue-br);  }
    .b-pa { background: var(--amber-bg); color: var(--amber-tx); border-color: var(--amber-br); }
    .b-ap { background: var(--green-bg); color: var(--green-tx); border-color: var(--green-br); }
    .b-pp { background: var(--blue-bg);  color: var(--blue-tx);  border-color: var(--blue-br);  }
    .b-pg { background: var(--green-bg); color: var(--green-tx); border-color: var(--green-br); }
    .b-co { background: var(--red-bg);   color: var(--red-tx);   border-color: var(--red-br);   }

    /* ── Meta grid ── */
    .card-meta {
      padding: .9rem 1.25rem;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
      gap: 10px;
      border-bottom: 1px solid var(--border);
    }
    .meta-item .lbl { font-size: 11px; color: var(--text-3); margin-bottom: 2px; }
    .meta-item .val { font-size: 13px; font-weight: 500; }

    /* ── Banner corrección ── */
    .corr-banner {
      margin: .75rem 1.25rem 0;
      padding: 8px 12px;
      background: var(--red-bg);
      border: 1px solid var(--red-br);
      border-radius: var(--radius-sm);
      font-size: 12px; color: var(--red-tx);
      display: flex; gap: 8px; align-items: flex-start;
    }
    .corr-banner i { font-size: 15px; flex-shrink: 0; margin-top: 1px; }

    /* ── Participantes ── */
    .participants-section { padding: .75rem 1.25rem 1rem; }
    .participants-label {
      font-size: 11px; color: var(--text-3);
      text-transform: uppercase; letter-spacing: .06em;
      margin-bottom: 8px;
    }
    .p-row {
      display: flex; align-items: center;
      justify-content: space-between;
      padding: 7px 10px;
      border-radius: var(--radius-sm);
      background: var(--bg);
      margin-bottom: 6px; gap: 8px;
    }
    .p-left  { display: flex; align-items: center; gap: 10px; }
    .p-avatar {
      width: 28px; height: 28px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 10px; font-weight: 500; flex-shrink: 0;
    }
    .p-avatar.asesor  { background: var(--blue-bg);  color: var(--blue-tx); }
    .p-avatar.gerente { background: var(--amber-bg); color: var(--amber-tx); }
    .p-name { font-size: 13px; font-weight: 500; }
    .p-role { font-size: 11px; color: var(--text-2); }
    .p-right { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
    .p-amount { font-family: 'DM Mono', monospace; font-size: 12px; color: var(--text-2); }

    .btn-verify {
      display: flex; align-items: center; gap: 5px;
      font-size: 11px; font-weight: 500;
      padding: 4px 10px; border-radius: 20px;
      border: 1px solid var(--border-md);
      background: var(--surface);
      cursor: pointer; color: var(--text-2);
      transition: all .15s; white-space: nowrap;
    }
    .btn-verify:hover:not(:disabled) {
      border-color: var(--green-tx);
      color: var(--green-tx);
      background: var(--green-bg);
    }
    .btn-verify.verified {
      border-color: var(--green-br);
      background: var(--green-bg);
      color: var(--green-tx);
      cursor: default;
    }
    .btn-verify i { font-size: 13px; }

    .p-verified { font-size: 11px; display: flex; align-items: center; gap: 4px; }
    .p-verified.yes { color: var(--green-tx); }
    .p-verified.no  { color: var(--text-3); }

    /* ── Acciones card ── */
    .card-actions {
      padding: .75rem 1.25rem 1rem;
      display: flex; gap: 8px; flex-wrap: wrap;
      border-top: 1px solid var(--border);
    }
    .btn {
      display: inline-flex; align-items: center; gap: 6px;
      font-size: 13px; font-weight: 500;
      padding: 7px 14px;
      border-radius: var(--radius-sm);
      border: 1px solid var(--border-md);
      background: transparent;
      cursor: pointer; color: var(--text-1);
      transition: background .15s, border-color .15s;
      font-family: 'DM Sans', sans-serif;
    }
    .btn:hover { background: var(--bg); }
    .btn i { font-size: 15px; }
    .btn-green { color: var(--green-tx); border-color: var(--green-br); }
    .btn-green:hover { background: var(--green-bg); }
    .btn-amber { color: var(--amber-tx); border-color: var(--amber-br); }
    .btn-amber:hover { background: var(--amber-bg); }

    /* ── Spinner ── */
    .spinner {
      width: 20px; height: 20px;
      border: 2px solid var(--border);
      border-top-color: var(--text-2);
      border-radius: 50%;
      animation: spin .7s linear infinite;
      margin: 0 auto 12px;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* ── Toast ── */
    #toast {
      position: fixed;
      bottom: 1.5rem; right: 1.5rem;
      background: var(--text-1); color: #fff;
      font-size: 13px;
      padding: 10px 16px;
      border-radius: var(--radius-sm);
      opacity: 0; pointer-events: none;
      transition: opacity .2s;
      z-index: 999; max-width: 280px;
    }
    #toast.show { opacity: 1; }
  </style>
</head>
<body>

<%- include('partials/sidebar') %>
<div class="main-area">
<%- include('partials/header') %>

<!-- Page -->
<main class="page">
  <div class="page-header">
    <h1 class="page-title" id="page-title">Comisiones</h1>
    <a href="/registrar-comision" class="btn-new" id="btnNew" style="display:none">
      <i class="ti ti-plus"></i>
      Nueva comisión
    </a>
    <span class="page-count" id="page-count"></span>
    
  </div>
  
  <div id="list"></div>
</main>

<div id="toast"></div>
</div><!-- /.main-area -->

<script>
const $ = id => document.getElementById(id);

function fmt(n) {
  return '$' + Number(n).toLocaleString('es-MX', { minimumFractionDigits: 0 });
}
function fmtDate(d) {
  if (!d) return '—';
  return new Date(d).toLocaleDateString('es-MX', { day:'2-digit', month:'short', year:'numeric' });
}
function initials(name) {
  return (name || '').split(' ').slice(0,2).map(w => w[0]).join('').toUpperCase();
}

let toastTimer;
function toast(msg) {
  const el = $('toast');
  el.textContent = msg;
  el.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => el.classList.remove('show'), 3000);
}

let USER = null;
let DATA = [];

const STATUS_MAP = {
  'Pendiente Verificacion': { cls: 'b-pv', label: 'Pendiente verificación' },
  'Verificada':             { cls: 'b-v',  label: 'Verificada'             },
  'Pendiente Aprobacion':   { cls: 'b-pa', label: 'Pendiente aprobación'   },
  'Aprobada':               { cls: 'b-ap', label: 'Aprobada'               },
  'Pendiente Pago':         { cls: 'b-pp', label: 'Pendiente pago'         },
  'Pagada':                 { cls: 'b-pg', label: 'Pagada'                 },
  'Correccion':             { cls: 'b-co', label: 'Corrección'             },
};

// ── Bootstrap ─────────────────────────────────────────────────────────────────
async function init() {
  try {
    const r = await fetch('/api/auth/me', { credentials: 'include' });
    const j = await r.json();
    if (!j.success) { showError('Sesión no válida. Inicia sesión.'); return; }
    USER = j.data.user;
  } catch(e) {
    showError('No se pudo conectar con el servidor.');
    return;
  }


  // Mostrar "Nueva comisión" para Gerente, Directora y Administradora
  const rolesConAcceso = ['Gerente', 'Directora', 'Administradora'];
  if (rolesConAcceso.includes(USER.roleName)) {
    $('btnNew').style.display = 'flex';
  }

  const isLimitado = ['Asesor', 'Gerente'].includes(USER.roleName);
  $('page-title').textContent = isLimitado ? 'Mis comisiones' : 'Todas las comisiones';
  await loadComisiones(isLimitado);
}

// ── Logout ─────────────────────────────────────────────────────────────────────
function showLogoutModal() {
  if (document.getElementById('logoutModal')) return;
  const overlay = document.createElement('div');
  overlay.className = 'modal-overlay';
  overlay.id = 'logoutModal';
  overlay.innerHTML = `
    <div class="modal" role="dialog" aria-modal="true">
      <div class="modal-icon"><i class="ti ti-logout"></i></div>
      <h3>Cerrar sesión</h3>
      <p>¿Seguro que quieres salir? Tu sesión se cerrará y tendrás que volver a iniciar.</p>
      <div class="modal-btns">
        <button class="mbtn" onclick="closeLogoutModal()">Cancelar</button>
        <button class="mbtn mbtn-danger" id="confirmLogoutBtn" onclick="doLogout()">Cerrar sesión</button>
      </div>
    </div>`;
  overlay.addEventListener('click', e => { if (e.target === overlay) closeLogoutModal(); });
  document.body.appendChild(overlay);
}

function closeLogoutModal() {
  const m = document.getElementById('logoutModal');
  if (m) m.remove();
}

async function doLogout() {
  const btn = $('confirmLogoutBtn');
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner-sm"></span> Saliendo…';
  try {
    await fetch('/api/auth/logout', { method: 'POST', credentials: 'include' });
  } catch(e) { /* limpiamos igual */ }
  finally {
  window.location.href = "/"
}
  
  closeLogoutModal();
  USER = null; DATA = [];
  $('av').textContent    = '';
  $('uname').textContent = '—';
  $('urole').textContent = '—';
  $('btnLogout').style.display = 'none';
  $('btnNew').style.display    = 'none';
  $('page-count').textContent  = '';
  showError('Sesión cerrada. <a href="/login" style="color:var(--text-1);font-weight:500">Volver a iniciar sesión →</a>');
} 

// ── Comisiones ────────────────────────────────────────────────────────────────
async function loadComisiones(misComisiones) {
  $('list').innerHTML = `<div class="state-msg"><div class="spinner"></div>Cargando comisiones…</div>`;
  const url = misComisiones ? '/api/comisiones/mis-comisiones' : '/api/comisiones';
  try {
    const r = await fetch(url, { credentials: 'include' });
    const j = await r.json();
    if (!j.success) { showError(j.message); return; }
    DATA = j.data.filas || j.data.comisiones || j.data || [];
    $('page-count').textContent = `${DATA.length} comisión${DATA.length !== 1 ? 'es' : ''}`;
    render();
  } catch(e) {
    showError('Error al obtener las comisiones.');
  }
}

function render() {
  if (!DATA.length) {
    $('list').innerHTML = `<div class="state-msg"><i class="ti ti-inbox"></i>Sin comisiones para mostrar</div>`;
    return;
  }
  $('list').innerHTML = DATA.map(cardHTML).join('');
}

function cardHTML(c) {
  const st = STATUS_MAP[c.status?.name] || { cls: 'b-v', label: c.status?.name || '—' };

  // Botones editar/eliminar solo para Gerente
  // const gerenteActions = USER.roleName === 'Gerente' ? `
  //   <button class="btn-icon edit"   title="Editar comisión"   onclick="editarComision('${c._id}')"><i class="ti ti-pencil"></i></button>
  //   <button class="btn-icon delete" title="Eliminar comisión" onclick="eliminarComision('${c._id}')"><i class="ti ti-trash"></i></button>
  // ` : '';

  const isCreador = c.created_by === USER.id;
  console.log(c.created_by);
  const gerenteActions = isCreador ? `
    <button class="btn-icon edit"   title="Editar"   onclick="editarComision('${c._id}')"><i class="ti ti-pencil"></i></button>
    <button class="btn-icon delete" title="Eliminar" onclick="eliminarComision('${c._id}', '${c.location?.text}')"><i class="ti ti-trash"></i></button>
  ` : '';

  const partRows = (c.participantes || []).map(p => {
    const isMe = p.usuario?._id === USER.id;
    let rightHtml;
    if (isMe && c.status?.name === 'Pendiente Verificacion') {
      rightHtml = `
        <span class="p-amount">${fmt(p.commission_amount)}</span>
        <button class="btn-verify ${p.verification ? 'verified' : ''}"
          onclick="verificar('${c._id}')"
          ${p.verification ? 'disabled' : ''}>
          <i class="ti ${p.verification ? 'ti-circle-check' : 'ti-circle'}"></i>
          ${p.verification ? 'Verificado' : 'Verificar'}
        </button>`;
    } else {
      rightHtml = `
        <span class="p-amount">${fmt(p.commission_amount)}</span>
        <span class="p-verified ${p.verification ? 'yes' : 'no'}">
          <i class="ti ${p.verification ? 'ti-circle-check' : 'ti-circle'}" style="font-size:13px"></i>
          ${p.verification ? 'Verificado' : 'Pendiente'}
        </span>`;
    }
    return `
      <div class="p-row">
        <div class="p-left">
          <div class="p-avatar ${p.role_in_comision}">${initials(p.usuario?.name)}</div>
          <div>
            <div class="p-name">${p.usuario?.name || '—'}${isMe ? ' <span style="font-size:10px;color:var(--text-3)">(tú)</span>' : ''}</div>
            <div class="p-role">${p.role_in_comision}</div>
          </div>
        </div>
        <div class="p-right">${rightHtml}</div>
      </div>`;
  }).join('');

  const corrBanner = c.correction_comments
    ? `<div class="corr-banner"><i class="ti ti-alert-triangle"></i><span>${c.correction_comments}</span></div>`
    : '';

  let actions = '';
  const sName = c.status?.name;
  if (USER.roleName === 'Directora' && sName === 'Pendiente Aprobacion') {
    actions = `
      <button class="btn btn-green" onclick="aprobar('${c._id}','aprobar')"><i class="ti ti-circle-check"></i>Aprobar</button>
      <button class="btn btn-amber" onclick="pedirCorreccion('${c._id}')"><i class="ti ti-alert-circle"></i>Corregir</button>`;
  }
  if (USER.roleName === 'Administradora' && sName === 'Pendiente Pago') {
    actions = `
      <button class="btn btn-green" onclick="pagar('${c._id}')"><i class="ti ti-cash"></i>Marcar como pagada</button>
      <button class="btn btn-amber" onclick="pedirCorreccion('${c._id}')"><i class="ti ti-alert-circle"></i>Corregir</button>`;
  }

  return `
    <div class="card" id="card-${c._id}">
      <div class="card-head">
        <div>
          <div class="card-loc">${c.location?.text || '—'}</div>
          <div class="card-dev">${c.development?.text || ''} · ${c.company?.text || ''}</div>
        </div>
        <div class="card-head-right">
          ${gerenteActions}
          <span class="badge ${st.cls}">${st.label}</span>
        </div>
      </div>
      <div class="card-meta">
       <div class="meta-item"><div class="lbl">Cliente</div><div class="val">${c.client_name || '—'}</div></div>
<div class="meta-item"><div class="lbl">Tipo</div><div class="val">${c.commission_type || '—'}</div></div>
<div class="meta-item"><div class="lbl">Concepto</div><div class="val">${c.concept?.text || '—'}</div></div>
<div class="meta-item"><div class="lbl">Precio venta</div><div class="val">${fmt(c.sale_price)}</div></div>
<div class="meta-item"><div class="lbl">Comisión total</div><div class="val">${fmt(c.total_commission)}</div></div>
<div class="meta-item"><div class="lbl">Fecha operación</div><div class="val">${fmtDate(c.operation_date)}</div></div>
