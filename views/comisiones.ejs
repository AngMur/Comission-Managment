<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Comisiones</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:       #f5f4f0;
      --surface:  #ffffff;
      --border:   #e2e0d8;
      --border-md:#c8c5bc;
      --text-1:   #1a1917;
      --text-2:   #6b6860;
      --text-3:   #9c9a94;
      --accent:   #1a1917;
      --green-bg: #eaf3de;
      --green-tx: #3b6d11;
      --green-br: #c0dd97;
      --amber-bg: #faeeda;
      --amber-tx: #854f0b;
      --amber-br: #fac775;
      --red-bg:   #fcebeb;
      --red-tx:   #a32d2d;
      --red-br:   #f7c1c1;
      --blue-bg:  #e6f1fb;
      --blue-tx:  #185fa5;
      --blue-br:  #b5d4f4;
      --gray-bg:  #f1efe8;
      --gray-tx:  #5f5e5a;
      --gray-br:  #d3d1c7;
      --radius:   10px;
      --radius-sm:6px;
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--text-1);
      min-height: 100vh;
    }

    /* ── Topbar ── */
    .topbar {
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      padding: 0 2rem;
      height: 56px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 10;
    }
    .topbar-brand {
      font-family: 'DM Mono', monospace;
      font-size: 13px;
      font-weight: 500;
      letter-spacing: .04em;
      color: var(--text-1);
    }
    .topbar-user {
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .avatar {
      width: 32px; height: 32px;
      border-radius: 50%;
      background: var(--text-1);
      color: #fff;
      display: flex; align-items: center; justify-content: center;
      font-size: 11px; font-weight: 500;
      letter-spacing: .03em;
      flex-shrink: 0;
    }
    .topbar-user-info p  { font-size: 13px; font-weight: 500; line-height: 1.2; }
    .topbar-user-info span { font-size: 11px; color: var(--text-2); }

    /* ── Layout ── */
    .page { max-width: 860px; margin: 0 auto; padding: 2rem 1.5rem; }

    .page-header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      margin-bottom: 1.75rem;
      gap: 12px;
      flex-wrap: wrap;
    }
    .page-title { font-size: 20px; font-weight: 500; }
    .page-count { font-size: 13px; color: var(--text-2); }

    /* ── Estado skeleton / error ── */
    .state-msg {
      text-align: center;
      padding: 4rem 1rem;
      color: var(--text-2);
      font-size: 14px;
    }
    .state-msg i { font-size: 36px; display: block; margin-bottom: 10px; color: var(--text-3); }

    /* ── Card ── */
    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      margin-bottom: 1rem;
      overflow: hidden;
      animation: fadeUp .25s ease both;
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(8px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .card-head {
      padding: 1.1rem 1.25rem .9rem;
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 12px;
      border-bottom: 1px solid var(--border);
    }
    .card-loc  { font-family: 'DM Mono', monospace; font-size: 13px; font-weight: 500; color: var(--text-1); }
    .card-dev  { font-size: 12px; color: var(--text-2); margin-top: 2px; }

    /* ── Badge ── */
    .badge {
      font-size: 11px; font-weight: 500;
      padding: 3px 9px;
      border-radius: 20px;
      border: 1px solid;
      white-space: nowrap;
      flex-shrink: 0;
    }
    .b-pv { background: var(--amber-bg); color: var(--amber-tx); border-color: var(--amber-br); }
    .b-v  { background: var(--blue-bg);  color: var(--blue-tx);  border-color: var(--blue-br);  }
    .b-pa { background: var(--amber-bg); color: var(--amber-tx); border-color: var(--amber-br); }
    .b-ap { background: var(--green-bg); color: var(--green-tx); border-color: var(--green-br); }
    .b-pp { background: var(--blue-bg);  color: var(--blue-tx);  border-color: var(--blue-br);  }
    .b-pg { background: var(--green-bg); color: var(--green-tx); border-color: var(--green-br); }
    .b-co { background: var(--red-bg);   color: var(--red-tx);   border-color: var(--red-br);   }

    /* ── Meta grid ── */
    .card-meta {
      padding: .9rem 1.25rem;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
      gap: 10px;
      border-bottom: 1px solid var(--border);
    }
    .meta-item .lbl { font-size: 11px; color: var(--text-3); margin-bottom: 2px; }
    .meta-item .val { font-size: 13px; font-weight: 500; }

    /* ── Banner corrección ── */
    .corr-banner {
      margin: 0 1.25rem .75rem;
      padding: 8px 12px;
      background: var(--red-bg);
      border: 1px solid var(--red-br);
      border-radius: var(--radius-sm);
      font-size: 12px;
      color: var(--red-tx);
      display: flex;
      gap: 8px;
      align-items: flex-start;
      margin-top: .75rem;
    }
    .corr-banner i { font-size: 15px; flex-shrink: 0; margin-top: 1px; }

    /* ── Participantes ── */
    .participants-section { padding: .75rem 1.25rem 1rem; }
    .participants-label {
      font-size: 11px;
      color: var(--text-3);
      text-transform: uppercase;
      letter-spacing: .06em;
      margin-bottom: 8px;
    }
    .p-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 7px 10px;
      border-radius: var(--radius-sm);
      background: var(--bg);
      margin-bottom: 6px;
      gap: 8px;
    }
    .p-left  { display: flex; align-items: center; gap: 10px; }
    .p-avatar {
      width: 28px; height: 28px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 10px; font-weight: 500;
      flex-shrink: 0;
    }
    .p-avatar.asesor  { background: var(--blue-bg);  color: var(--blue-tx); }
    .p-avatar.gerente { background: var(--amber-bg); color: var(--amber-tx); }
    .p-name { font-size: 13px; font-weight: 500; }
    .p-role { font-size: 11px; color: var(--text-2); }
    .p-right { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
    .p-amount { font-family: 'DM Mono', monospace; font-size: 12px; color: var(--text-2); }

    /* ── Botón verificar ── */
    .btn-verify {
      display: flex; align-items: center; gap: 5px;
      font-size: 11px; font-weight: 500;
      padding: 4px 10px;
      border-radius: 20px;
      border: 1px solid var(--border-md);
      background: var(--surface);
      cursor: pointer;
      color: var(--text-2);
      transition: all .15s;
      white-space: nowrap;
    }
    .btn-verify:hover:not(:disabled) {
      border-color: var(--green-tx);
      color: var(--green-tx);
      background: var(--green-bg);
    }
    .btn-verify.verified {
      border-color: var(--green-br);
      background: var(--green-bg);
      color: var(--green-tx);
      cursor: default;
    }
    .btn-verify i { font-size: 13px; }

    /* verified badge (otros participantes) */
    .p-verified {
      font-size: 11px;
      display: flex; align-items: center; gap: 4px;
    }
    .p-verified.yes { color: var(--green-tx); }
    .p-verified.no  { color: var(--text-3); }

    /* ── Acciones ── */
    .card-actions {
      padding: .75rem 1.25rem 1rem;
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      border-top: 1px solid var(--border);
    }
    .btn {
      display: inline-flex; align-items: center; gap: 6px;
      font-size: 13px; font-weight: 500;
      padding: 7px 14px;
      border-radius: var(--radius-sm);
      border: 1px solid var(--border-md);
      background: transparent;
      cursor: pointer;
      color: var(--text-1);
      transition: background .15s, border-color .15s;
      font-family: 'DM Sans', sans-serif;
    }
    .btn:hover { background: var(--bg); }
    .btn i { font-size: 15px; }
    .btn-green { color: var(--green-tx); border-color: var(--green-br); }
    .btn-green:hover { background: var(--green-bg); }
    .btn-amber { color: var(--amber-tx); border-color: var(--amber-br); }
    .btn-amber:hover { background: var(--amber-bg); }

    /* ── Spinner ── */
    .spinner {
      width: 20px; height: 20px;
      border: 2px solid var(--border);
      border-top-color: var(--text-2);
      border-radius: 50%;
      animation: spin .7s linear infinite;
      margin: 0 auto 12px;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* ── Toast ── */
    #toast {
      position: fixed;
      bottom: 1.5rem; right: 1.5rem;
      background: var(--text-1);
      color: #fff;
      font-size: 13px;
      padding: 10px 16px;
      border-radius: var(--radius-sm);
      opacity: 0;
      pointer-events: none;
      transition: opacity .2s;
      z-index: 999;
      max-width: 280px;
    }
    #toast.show { opacity: 1; }
  </style>
</head>
<body>

<!-- Topbar -->
<header class="topbar">
  <span class="topbar-brand">COMISIONES</span>
  <div class="topbar-user">
    <div class="avatar" id="av"></div>
    <div class="topbar-user-info">
      <p id="uname">—</p>
      <span id="urole">—</span>
    </div>
  </div>
</header>

<!-- Page -->
<main class="page">
  <div class="page-header">
    <h1 class="page-title" id="page-title">Comisiones</h1>
    <span class="page-count" id="page-count"></span>
  </div>
  <div id="list"></div>
</main>

<div id="toast"></div>

<script>
// ── Helpers ──────────────────────────────────────────────────────────────────
const $ = id => document.getElementById(id);

function fmt(n) {
  return '$' + Number(n).toLocaleString('es-MX', { minimumFractionDigits: 0 });
}
function fmtDate(d) {
  if (!d) return '—';
  return new Date(d).toLocaleDateString('es-MX', { day:'2-digit', month:'short', year:'numeric' });
}
function initials(name) {
  return (name || '').split(' ').slice(0,2).map(w => w[0]).join('').toUpperCase();
}

let toastTimer;
function toast(msg) {
  const el = $('toast');
  el.textContent = msg;
  el.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => el.classList.remove('show'), 3000);
}

// ── Estado global ─────────────────────────────────────────────────────────────
let USER = null;   // objeto del JWT
let DATA = [];     // comisiones cargadas

const STATUS_MAP = {
  'Pendiente Verificacion': { cls: 'b-pv', label: 'Pendiente verificación' },
  'Verificada':             { cls: 'b-v',  label: 'Verificada'             },
  'Pendiente Aprobacion':   { cls: 'b-pa', label: 'Pendiente aprobación'   },
  'Aprobada':               { cls: 'b-ap', label: 'Aprobada'               },
  'Pendiente Pago':         { cls: 'b-pp', label: 'Pendiente pago'         },
  'Pagada':                 { cls: 'b-pg', label: 'Pagada'                 },
  'Correccion':             { cls: 'b-co', label: 'Corrección'             },
};

// ── Bootstrap ────────────────────────────────────────────────────────────────
async function init() {
  // 1. Obtener usuario desde cookie/JWT
  try {
    const r = await fetch('/api/auth/me', { credentials: 'include' });
    const j = await r.json();
    if (!j.success) { showError('Sesión no válida. Inicia sesión.'); return; }
    USER = j.data.user;
  } catch(e) {
    showError('No se pudo conectar con el servidor.');
    return;
  }

  // 2. Pintar topbar
  $('av').textContent    = initials(USER.name);
  $('uname').textContent = USER.name;
  $('urole').textContent = USER.roleName;

  // 3. Elegir endpoint según rol
  const isLimitado = ['Asesor', 'Gerente'].includes(USER.roleName);
  $('page-title').textContent = isLimitado ? 'Mis comisiones' : 'Todas las comisiones';

  await loadComisiones(isLimitado);
}

// ── Carga de comisiones ───────────────────────────────────────────────────────
async function loadComisiones(misComisiones) {
  $('list').innerHTML = `<div class="state-msg"><div class="spinner"></div>Cargando comisiones…</div>`;

  const url = misComisiones ? '/api/comisiones/mis-comisiones' : '/api/comisiones';
  try {
    const r = await fetch(url, { credentials: 'include' });
    const j = await r.json();
    if (!j.success) { showError(j.message); return; }
    DATA = j.data;
    $('page-count').textContent = `${DATA.length} comisión${DATA.length !== 1 ? 'es' : ''}`;
    render();
  } catch(e) {
    showError('Error al obtener las comisiones.');
  }
}

// ── Render ────────────────────────────────────────────────────────────────────
function render() {
  if (!DATA.length) {
    $('list').innerHTML = `<div class="state-msg"><i class="ti ti-inbox"></i>Sin comisiones para mostrar</div>`;
    return;
  }
  $('list').innerHTML = DATA.map(cardHTML).join('');
}

function cardHTML(c) {
  const st = STATUS_MAP[c.status?.name] || { cls: 'b-v', label: c.status?.name || '—' };
  const isCreator = c.created_by?._id === USER.id;

  // participantes
  const partRows = (c.participantes || []).map((p, i) => {
    const isMe = p.usuario?._id === USER.id;
    let rightHtml;

    if (isMe && c.status?.name === 'Pendiente Verificacion') {
      rightHtml = `
        <span class="p-amount">${fmt(p.commission_amount)}</span>
        <button class="btn-verify ${p.verification ? 'verified' : ''}"
          onclick="verificar('${c._id}')"
          ${p.verification ? 'disabled' : ''}>
          <i class="ti ${p.verification ? 'ti-circle-check' : 'ti-circle'}"></i>
          ${p.verification ? 'Verificado' : 'Verificar'}
        </button>`;
    } else {
      const vIcon = p.verification ? 'ti-circle-check' : 'ti-circle';
      const vCls  = p.verification ? 'yes' : 'no';
      const vTxt  = p.verification ? 'Verificado' : 'Pendiente';
      rightHtml = `
        <span class="p-amount">${fmt(p.commission_amount)}</span>
        <span class="p-verified ${vCls}"><i class="ti ${vIcon}" style="font-size:13px"></i>${vTxt}</span>`;
    }

    return `
      <div class="p-row">
        <div class="p-left">
          <div class="p-avatar ${p.role_in_comision}">${initials(p.usuario?.name)}</div>
          <div>
            <div class="p-name">${p.usuario?.name || '—'}${isMe ? ' <span style="font-size:10px;color:var(--text-3)">(tú)</span>' : ''}</div>
            <div class="p-role">${p.role_in_comision}</div>
          </div>
        </div>
        <div class="p-right">${rightHtml}</div>
      </div>`;
  }).join('');

  // banner corrección
  const corrBanner = c.correction_comments
    ? `<div class="corr-banner">
        <i class="ti ti-alert-triangle"></i>
        <span>${c.correction_comments}</span>
      </div>`
    : '';

  // acciones según rol + estatus
  let actions = '';
  const sName = c.status?.name;

  if (USER.roleName === 'Directora' && sName === 'Pendiente Aprobacion') {
    actions += `
      <button class="btn btn-green" onclick="aprobar('${c._id}', 'aprobar')">
        <i class="ti ti-circle-check"></i> Aprobar
      </button>
      <button class="btn btn-amber" onclick="pedirCorreccion('${c._id}')">
        <i class="ti ti-alert-circle"></i> Corregir
      </button>`;
  }

  if (USER.roleName === 'Administradora' && sName === 'Pendiente Pago') {
    actions += `
      <button class="btn btn-green" onclick="pagar('${c._id}')">
        <i class="ti ti-cash"></i> Marcar como pagada
      </button>
      <button class="btn btn-amber" onclick="pedirCorreccion('${c._id}')">
        <i class="ti ti-alert-circle"></i> Corregir
      </button>`;
  }

  const actionsBlock = actions
    ? `<div class="card-actions">${actions}</div>`
    : '';

  return `
    <div class="card" id="card-${c._id}">
      <div class="card-head">
        <div>
          <div class="card-loc">${c.location?.text || '—'}</div>
          <div class="card-dev">${c.development?.text} · ${c.company?.text}</div>
        </div>
        <span class="badge ${st.cls}">${st.label}</span>
      </div>

      <div class="card-meta">
        <div class="meta-item"><div class="lbl">Cliente</div><div class="val">${c.client_name || '—'}</div></div>
        <div class="meta-item"><div class="lbl">Tipo</div><div class="val">${c.commission_type}</div></div>
        <div class="meta-item"><div class="lbl">Precio venta</div><div class="val">${fmt(c.sale_price)}</div></div>
        <div class="meta-item"><div class="lbl">Comisión total</div><div class="val">${fmt(c.total_commission)}</div></div>
        <div class="meta-item"><div class="lbl">Fecha operación</div><div class="val">${fmtDate(c.operation_date)}</div></div>
      </div>

      ${corrBanner}

      <div class="participants-section">
        <div class="participants-label">Participantes</div>
        ${partRows}
      </div>

      ${actionsBlock}
    </div>`;
}

// ── Acciones ──────────────────────────────────────────────────────────────────
async function verificar(comisionId) {
  try {
    const r = await fetch(`/api/comisiones/${comisionId}/verificar`, {
      method: 'PATCH',
      credentials: 'include',
    });
    const j = await r.json();
    if (!j.success) { toast(j.message); return; }
    toast(j.message);
    await reloadComision(comisionId);
  } catch(e) { toast('Error al verificar'); }
}

async function aprobar(comisionId, accion, correction_comments = null) {
  const body = { accion };
  if (correction_comments) body.correction_comments = correction_comments;

  try {
    const r = await fetch(`/api/comisiones/${comisionId}/aprobar`, {
      method: 'PATCH',
      credentials: 'include',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });
    const j = await r.json();
    if (!j.success) { toast(j.message); return; }
    toast(j.message);
    await reloadComision(comisionId);
  } catch(e) { toast('Error al procesar'); }
}

async function pagar(comisionId) {
  try {
    const r = await fetch(`/api/comisiones/${comisionId}/pagar`, {
      method: 'PATCH',
      credentials: 'include',
    });
    const j = await r.json();
    if (!j.success) { toast(j.message); return; }
    toast(j.message);
    await reloadComision(comisionId);
  } catch(e) { toast('Error al marcar como pagada'); }
}

function pedirCorreccion(comisionId) {
  const comentario = prompt('Indica el motivo de la corrección:');
  if (!comentario) return;

  // Directora usa /aprobar con accion=correccion
  // Administradora también puede usar el mismo endpoint o uno propio
  aprobar(comisionId, 'correccion', comentario);
}

// ── Recarga una sola comisión sin recargar toda la lista ──────────────────────
async function reloadComision(comisionId) {
  // Recargamos todo el listado para mantener consistencia
  const isLimitado = ['Asesor', 'Gerente'].includes(USER.roleName);
  await loadComisiones(isLimitado);
}

// ── Error global ──────────────────────────────────────────────────────────────
function showError(msg) {
  $('list').innerHTML = `<div class="state-msg"><i class="ti ti-alert-circle"></i>${msg}</div>`;
}

// ── Arrancar ──────────────────────────────────────────────────────────────────
init();
</script>
</body>
</html>